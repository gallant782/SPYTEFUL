# =============================================================================
# MindFrame — Environment Configuration (.env)
# =============================================================================
# Copy this file to the repo root (or wherever you run Docker Compose from):
#   cp engineering/deploy/.env.example .env
#
# This file is loaded automatically by docker-compose.yml.
# Fill in every value marked with CHANGE-ME or YOUR- before deploying.
# =============================================================================

# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 1: n8n Automation Server
# ═══════════════════════════════════════════════════════════════════════════════

# Host domain (set to your actual domain in production: n8n.mindframe.ai)
N8N_HOST=localhost
N8N_PROTOCOL=http

# Encryption key — generate with: openssl rand -base64 32
# ⚠️  If you change this after n8n has saved credentials, they will be lost.
N8N_ENCRYPTION_KEY=CHANGE-ME-to-a-32-char-random-string-abcdef1234

# PostgreSQL for n8n internal state (runs in Docker alongside n8n)
N8N_DB_HOST=n8n-db
N8N_DB_PORT=5432
N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=CHANGE-ME-n8n-db-password-123

# Execution mode: "regular" (single process) or "queue" (multi-worker)
N8N_EXECUTIONS_MODE=regular

# Redis (only needed when EXECUTIONS_MODE=queue — not used at launch)
REDIS_HOST=n8n-redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 2: Supabase (Business Database)
# ═══════════════════════════════════════════════════════════════════════════════

# Get these from: Supabase Dashboard → Settings → API
# Or run: ./engineering/deploy/supabase-setup.sh  (outputs them automatically)
MINDFRAME_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
MINDFRAME_SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase CLI (only needed once for supabase-setup.sh)
SUPABASE_ACCESS_TOKEN=sbp_YOUR-SUPABASE-ACCESS-TOKEN
SUPABASE_ORG_ID=YOUR-ORG-ID
SUPABASE_DB_PASSWORD=CHANGE-ME-supabase-db-password-32chars

# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 3: AI Providers
# ═══════════════════════════════════════════════════════════════════════════════

# OpenAI — for script generation (Workflow 01)
# Get key: https://platform.openai.com/api-keys
MINDFRAME_OPENAI_API_KEY=sk-proj-YOUR-OPENAI-KEY

# ElevenLabs — for voiceover generation (Workflow 01, optional at launch)
# Get key: https://elevenlabs.io/app/settings/api-keys
MINDFRAME_ELEVENLABS_API_KEY=YOUR-ELEVENLABS-KEY

# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 4: Payment Processors
# ═══════════════════════════════════════════════════════════════════════════════

# Stripe Secret Key — for server-side payment processing
# Get from: https://dashboard.stripe.com/apikeys
# Use sk_test_... for development, sk_live_... for production
MINDFRAME_STRIPE_SECRET_KEY=sk_live_YOUR-STRIPE-SECRET-KEY

# Stripe Publishable Key — for client-side (landing pages, checkout forms)
# This goes in your frontend code, not in n8n directly, but keep it here
# for reference. Get from: https://dashboard.stripe.com/apikeys
MINDFRAME_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR-STRIPE-PUBLISHABLE-KEY

# Stripe Webhook Secret — for verifying webhook signatures
# Get from: https://dashboard.stripe.com/webhooks (create an endpoint)
# Endpoint URL: https://your-n8n-host/webhook/mindframe/stripe-purchase
# Events: checkout.session.completed, customer.subscription.*
MINDFRAME_STRIPE_WEBHOOK_SECRET=whsec_YOUR-WEBHOOK-SIGNING-SECRET

# Gumroad Access Token — for digital product sales
# Get from: https://app.gumroad.com/settings/advanced#access-token
MINDFRAME_GUMROAD_ACCESS_TOKEN=YOUR-GUMROAD-ACCESS-TOKEN

# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 5: Email Marketing
# ═══════════════════════════════════════════════════════════════════════════════

# Beehiiv API Key — for email campaigns and subscriber management
# Get from: https://app.beehiiv.com/settings/integrations
MINDFRAME_BEEHIIV_API_KEY=YOUR-BEEHIIV-API-KEY

# ConvertKit API Key — alternative to Beehiiv (not needed if using Beehiiv)
MINDFRAME_CONVERTKIT_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 6: SMTP (Email Fallback — used by n8n for admin alerts)
# ═══════════════════════════════════════════════════════════════════════════════

MINDFRAME_SMTP_HOST=smtp.sendgrid.net
MINDFRAME_SMTP_PORT=587
MINDFRAME_SMTP_USER=apikey
MINDFRAME_SMTP_PASS=SG.YOUR-SENDGRID-KEY
MINDFRAME_SMTP_FROM=noreply@mindframe.ai

# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 7: Admin & Monitoring
# ═══════════════════════════════════════════════════════════════════════════════

# Where to send daily metrics summaries and deployment alerts
ADMIN_EMAIL=admin@mindframe.ai