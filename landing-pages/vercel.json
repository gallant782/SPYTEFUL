{
  "name": "MindFrame Landing Pages",
  "version": 2,
  "buildCommand": null,
  "outputDirectory": ".",
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/product", "dest": "/product.html" },
    { "src": "/vault", "dest": "/product.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "redirects": [
    { "source": "/product", "destination": "/product.html", "permanent": true },
    { "source": "/vault", "destination": "/product.html", "permanent": true }
  ],
  "env": {
    "MINDFRAME_STRIPE_PUBLISHABLE_KEY": "@stripe_publishable_key"
  }
}