{
  "name": "Welcome Sequence Automator (5-Day Drip)",
  "nodes": [
    {
      "id": "webhook-trigger",
      "name": "Webhook: New Lead/Purchase",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300],
      "parameters": {
        "path": "mindframe/welcome-sequence",
        "options": {
          "responseMode": "responseNode"
        }
      },
      "webhookId": "mindframe-welcome"
    },
    {
      "id": "parse-input",
      "name": "Parse Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [450, 300],
      "parameters": {
        "jsCode": "const body = $input.first().json;\n\nreturn {\n  email: body.email,\n  subscriber_id: body.subscriber_id,\n  profile_id: body.profile_id || null,\n  trigger_type: body.trigger_type || 'lead_magnet', // 'lead_magnet' or 'purchase'\n  subscriber_name: body.full_name || body.email.split('@')[0],\n  sequence_start: new Date().toISOString()\n};"
      }
    },
    {
      "id": "record-sequence",
      "name": "Record Sequence Start in DB",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2,
      "position": [650, 300],
      "parameters": {
        "operation": "executeQuery",
        "query": "-- Tag subscriber with welcome sequence started\nINSERT INTO email_tags (name, slug, description)\nVALUES ('Welcome Sequence: Started', 'welcome-started', 'Currently in 5-day welcome drip')\nON CONFLICT (slug) DO NOTHING;\n\nINSERT INTO email_subscriber_tags (subscriber_id, tag_id)\nSELECT '{{ $json.subscriber_id }}', id FROM email_tags WHERE slug = 'welcome-started'\nON CONFLICT DO NOTHING;"
      }
    },
    {
      "id": "day1-email",
      "name": "Day 1: Send Immediately",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [850, 150],
      "parameters": {
        "method": "POST",
        "url": "https://api.beehiiv.com/v2/campaigns/trigger",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {"name": "Authorization", "value": "Bearer {{ $credentials.beehiivApiKey }}"},
            {"name": "Content-Type", "value": "application/json"}
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {"name": "email", "value": "={{ $json.email }}"},
            {"name": "campaign_id", "value": "={{ $env.WELCOME_DAY1_CAMPAIGN_ID }}"},
            {"name": "send_immediately", "value": true}
          ]
        },
        "options": {
          "timeout": 10000
        }
      }
    },
    {
      "id": "wait-day2",
      "name": "Wait 24 Hours",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [850, 350],
      "parameters": {
        "amount": 24,
        "unit": "hours"
      }
    },
    {
