    {
      "id": "mark-complete",
      "name": "Mark Sequence Complete",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2,
      "position": [1850, 250],
      "parameters": {
        "operation": "executeQuery",
        "query": "-- Tag subscriber with welcome sequence completed\nINSERT INTO email_tags (name, slug, description)\nVALUES ('Welcome Sequence: Completed', 'welcome-completed', 'Finished the 5-day welcome drip')\nON CONFLICT (slug) DO NOTHING;\n\nINSERT INTO email_subscriber_tags (subscriber_id, tag_id)\nSELECT '{{ $json.subscriber_id }}', id FROM email_tags WHERE slug = 'welcome-completed'\nON CONFLICT DO NOTHING;\n\n-- Remove 'started' tag\nDELETE FROM email_subscriber_tags\nWHERE subscriber_id = '{{ $json.subscriber_id }}'\nAND tag_id IN (SELECT id FROM email_tags WHERE slug = 'welcome-started');"
      }
    },
    {
      "id": "respond-webhook",
      "name": "Respond OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [2050, 250],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\n  \"success\": true,\n  \"subscriber_id\": \"{{ $json.subscriber_id }}\",\n  \"sequence\": \"5-day welcome\",\n  \"status\": \"started\"\n}"
      }
    }
