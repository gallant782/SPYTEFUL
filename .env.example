# =============================================================================
# MindFrame — Environment Configuration
# =============================================================================
# Copy this to .env and fill in your values:
#   cp .env.example .env
#   vim .env  (fill in secrets)
#
# Then launch:  ./scripts/launch.sh
# =============================================================================

# =============================================================================
# SECTION 1: n8n Automation Server
# =============================================================================

# n8n host configuration (change to your domain/IP in production)
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_ENCRYPTION_KEY=change-me-to-a-long-random-string-32-chars-minimum

# n8n database (PostgreSQL — runs inside Docker)
N8N_DB_HOST=n8n-db
N8N_DB_PORT=5432
N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=change-me-n8n-db-password

# n8n execution mode (regular = in-process, queue = via Redis workers)
N8N_EXECUTIONS_MODE=regular

# Redis (for queue mode — leave defaults if not using queue)
REDIS_HOST=n8n-redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_REQUIREPASS=false

# =============================================================================
# SECTION 2: Supabase (Cloud — https://supabase.com)
# =============================================================================

# Get these from Supabase Dashboard → Settings → API
MINDFRAME_SUPABASE_URL=https://your-project-id.supabase.co
MINDFRAME_SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIs...

# =============================================================================
# SECTION 3: AI Providers
# =============================================================================

# OpenAI — https://platform.openai.com/api-keys
MINDFRAME_OPENAI_API_KEY=sk-proj-your-openai-key-here

# ElevenLabs — https://elevenlabs.io/app/settings/api-keys
MINDFRAME_ELEVENLABS_API_KEY=your-elevenlabs-key

# =============================================================================
# SECTION 4: Payment Processors
# =============================================================================

# Stripe — https://dashboard.stripe.com/apikeys
MINDFRAME_STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
MINDFRAME_STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# Gumroad — https://app.gumroad.com/settings/advanced#access-token
MINDFRAME_GUMROAD_ACCESS_TOKEN=your-gumroad-token

# =============================================================================
# SECTION 5: Email Marketing
# =============================================================================

# ConvertKit — https://app.convertkit.com/account_settings/advanced_settings
MINDFRAME_CONVERTKIT_API_KEY=your-convertkit-api-key
MINDFRAME_CONVERTKIT_API_SECRET=your-convertkit-api-secret

# =============================================================================
# SECTION 6: Supabase CLI (for setup-supabase.sh)
# =============================================================================

# Get from Supabase Dashboard → Account → Access Tokens
# https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_your-supabase-access-token

# Your Supabase organization ID
# https://supabase.com/dashboard/org/<org-id>/general
SUPABASE_ORG_ID=your-org-id

# Name for the new Supabase project (lowercase, no spaces)
SUPABASE_PROJECT_NAME=mindframe-prod

# Database password for the Supabase project
SUPABASE_DB_PASSWORD=your-database-password-32-chars

# =============================================================================
# SECTION 7: n8n Campaign IDs (set these in n8n after importing workflows)
# =============================================================================

# Create these campaigns in ConvertKit first, then copy the IDs
WELCOME_DAY1_CAMPAIGN_ID=xxx
WELCOME_DAY2_CAMPAIGN_ID=xxx
WELCOME_DAY3_CAMPAIGN_ID=xxx
WELCOME_DAY4_CAMPAIGN_ID=xxx
WELCOME_DAY5_CAMPAIGN_ID=xxx
PURCHASE_WELCOME_CAMPAIGN_ID=xxx
MEMBERSHIP_WELCOME_CAMPAIGN_ID=xxx
MEMBERSHIP_UPDATE_CAMPAIGN_ID=xxx
CHURN_REMINDER_CAMPAIGN_ID=xxx

# =============================================================================
# SECTION 8: Admin & Monitoring
# =============================================================================
ADMIN_EMAIL=admin@mindframe.ai
